# MailerLite integration — required by netlify/functions/subscribe.ts
#
# Set these on Netlify: Site settings → Environment variables.
# They are read at request time by the Subscribe function and never shipped to the browser.
#
# MAILERLITE_API_KEY: Long-lived token from MailerLite → Integrations → Developer API.
# MAILERLITE_GROUP_ID: Numeric ID of the "Vesserath Readers" group
#   (Subscribers → Groups → click the group → ID is in the URL).

MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
